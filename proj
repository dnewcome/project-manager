#!/usr/bin/env python3
"""proj — browse and tag projects in ~/sandbox/dnewcome/"""

import argparse
import curses
import os
import re
import subprocess
import sys
import textwrap
import tomllib
import uuid
from datetime import datetime, timezone
from pathlib import Path

SANDBOX = Path.home() / "sandbox" / "dnewcome"


def git_last_commit(project_dir: Path) -> datetime | None:
    try:
        result = subprocess.run(
            ["git", "-C", str(project_dir), "log", "-1", "--format=%ct"],
            capture_output=True, text=True, timeout=5
        )
        ts = result.stdout.strip()
        if ts:
            return datetime.fromtimestamp(int(ts), tz=timezone.utc)
    except Exception:
        pass
    return None


def load_project(project_dir: Path) -> dict:
    toml_path = project_dir / ".project.toml"
    data = {}
    if toml_path.exists():
        with open(toml_path, "rb") as f:
            try:
                data = tomllib.load(f)
            except Exception:
                pass
    return {
        "path": project_dir,
        "name": data.get("name") or data.get("slug") or project_dir.name,
        "slug": data.get("slug") or project_dir.name,
        "description": data.get("description", ""),
        "tags": data.get("tags", []),
        "has_toml": toml_path.exists(),
        "last_commit": git_last_commit(project_dir),
        "_raw": data,
    }


def load_all_projects() -> list[dict]:
    projects = []
    for entry in sorted(SANDBOX.iterdir()):
        if entry.is_dir() and not entry.name.startswith("."):
            proj = load_project(entry)
            projects.append(proj)
    return projects


def fmt_age(dt: datetime | None) -> str:
    if dt is None:
        return "no git"
    delta = datetime.now(tz=timezone.utc) - dt
    days = delta.days
    if days == 0:
        return "today"
    if days == 1:
        return "yesterday"
    if days < 7:
        return f"{days}d ago"
    if days < 30:
        return f"{days // 7}w ago"
    if days < 365:
        return f"{days // 30}mo ago"
    return f"{days // 365}y ago"


def fmt_tags(tags: list) -> str:
    return " ".join(f"[{t}]" for t in tags) if tags else ""


def slugify(name: str) -> str:
    return re.sub(r"[^a-z0-9-]", "-", name.lower()).strip("-")


def split_toml_sections(raw: str) -> tuple[str, str]:
    """Split raw TOML into (scalar header, table sections).
    Everything from the first [section] or [[section]] line onwards is preserved verbatim."""
    for i, line in enumerate(raw.splitlines()):
        if re.match(r"^\[", line):
            header = "\n".join(raw.splitlines()[:i]).rstrip()
            sections = "\n".join(raw.splitlines()[i:])
            return header, sections
    return raw.rstrip(), ""


def build_header(proj_id: str, slug: str, name: str, description: str, tags: list[str]) -> str:
    lines = [
        f'id = "{proj_id}"',
        f'slug = "{slug}"',
        f'name = "{name}"',
    ]
    if description:
        lines.append(f'description = "{description}"')
    if tags:
        tag_str = ", ".join(f'"{t}"' for t in tags)
        lines.append(f"tags = [{tag_str}]")
    return "\n".join(lines)


def prompt(label: str, default: str = "") -> str:
    """Prompt only when running in a TTY."""
    if not sys.stdin.isatty():
        return default
    suffix = f" [{default}]" if default else ""
    val = input(f"{label}{suffix}: ").strip()
    return val or default


def resolve_project_dir(project_arg: str | None) -> Path:
    if project_arg:
        d = SANDBOX / project_arg
        if not d.exists():
            print(f"Project not found: {project_arg}", file=sys.stderr)
            sys.exit(1)
        return d
    return Path.cwd()


def cmd_list(args):
    if args.interactive:
        run_tui()
        return

    projects = load_all_projects()

    if args.tag:
        tag_lower = args.tag.lower()
        projects = [p for p in projects if any(tag_lower in t.lower() for t in p["tags"])]

    if args.recent:
        projects = [p for p in projects if p["last_commit"] is not None]
        projects.sort(key=lambda p: p["last_commit"], reverse=True)
        projects = projects[:args.recent]
    else:
        projects.sort(
            key=lambda p: p["last_commit"] or datetime.min.replace(tzinfo=timezone.utc),
            reverse=True
        )

    if not projects:
        print("No projects found.")
        return

    name_w = max(len(p["name"]) for p in projects)
    age_w = max(len(fmt_age(p["last_commit"])) for p in projects)

    for p in projects:
        age = fmt_age(p["last_commit"])
        tags = fmt_tags(p["tags"])
        toml_marker = "" if p["has_toml"] else " *"
        print(f"{p['name']:<{name_w}}{toml_marker}  {age:<{age_w}}  {tags}")
        if args.verbose and p["description"]:
            print(f"  {'':>{name_w}}  {p['description']}")


def cmd_show(args):
    project_dir = SANDBOX / args.project
    if not project_dir.exists():
        print(f"Project not found: {args.project}", file=sys.stderr)
        sys.exit(1)
    p = load_project(project_dir)
    print(f"Name:        {p['name']}")
    print(f"Slug:        {p['slug']}")
    print(f"Path:        {p['path']}")
    print(f"Last commit: {fmt_age(p['last_commit'])}")
    if p["description"]:
        print(f"Description: {p['description']}")
    print(f"Tags:        {', '.join(p['tags']) if p['tags'] else '(none)'}")
    if not p["has_toml"]:
        print("Note:        no .project.toml")


def cmd_init(args):
    project_dir = resolve_project_dir(args.project)
    toml_path = project_dir / ".project.toml"

    existing = {}
    raw = ""
    if toml_path.exists():
        raw = toml_path.read_text()
        with open(toml_path, "rb") as f:
            try:
                existing = tomllib.load(f)
            except Exception as e:
                print(f"Warning: could not parse existing .project.toml: {e}", file=sys.stderr)

    # Stable id — never overwrite if already set
    proj_id = existing.get("id") or str(uuid.uuid4())

    # Slug: flag > existing > infer from dir name
    slug = args.slug or existing.get("slug") or slugify(project_dir.name)

    # Name: flag > existing > prompt > dir name
    name = args.name or existing.get("name") or prompt("Name", project_dir.name)

    # Description: flag > existing > prompt
    description = args.description or existing.get("description") or prompt("Description")

    # Tags: merge existing + any new ones from flag
    tags = list(existing.get("tags", []))
    if args.tags:
        for t in args.tags:
            if t not in tags:
                tags.append(t)

    # Preserve any table sections from the existing file
    _, sections = split_toml_sections(raw)

    header = build_header(proj_id, slug, name, description, tags)
    content = header + ("\n\n" + sections if sections else "") + "\n"

    toml_path.write_text(content)

    action = "Updated" if existing else "Created"
    print(f"{action} {toml_path}")
    print(f"  id:          {proj_id}")
    print(f"  slug:        {slug}")
    print(f"  name:        {name}")
    if description:
        print(f"  description: {description}")
    if tags:
        print(f"  tags:        {', '.join(tags)}")


def cmd_tag(args):
    project_dir = SANDBOX / args.project
    if not project_dir.exists():
        print(f"Project not found: {args.project}", file=sys.stderr)
        sys.exit(1)

    toml_path = project_dir / ".project.toml"

    if toml_path.exists():
        raw = toml_path.read_text()
        with open(toml_path, "rb") as f:
            data = tomllib.load(f)
    else:
        raw = ""
        data = {}

    current_tags = list(data.get("tags", []))
    new_tags = [t for t in args.tags if t not in current_tags]

    if not new_tags:
        print(f"Tags already present: {', '.join(args.tags)}")
        return

    updated_tags = current_tags + new_tags
    tag_str = ", ".join(f'"{t}"' for t in updated_tags)
    new_line = f"tags = [{tag_str}]"

    if "tags" in data:
        raw = re.sub(r"^tags\s*=\s*\[.*?\]$", new_line, raw, flags=re.MULTILINE)
    else:
        if raw and not raw.endswith("\n"):
            raw += "\n"
        raw += new_line + "\n"

    toml_path.write_text(raw)
    print(f"Updated tags for {args.project}: {', '.join(updated_tags)}")


def cmd_tags(args):
    projects = load_all_projects()
    tag_counts: dict[str, int] = {}
    for p in projects:
        for t in p["tags"]:
            tag_counts[t] = tag_counts.get(t, 0) + 1

    if not tag_counts:
        print("No tags found across projects.")
        return

    for tag, count in sorted(tag_counts.items(), key=lambda x: -x[1]):
        print(f"{count:3}  {tag}")


